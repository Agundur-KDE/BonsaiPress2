{
    "name": "agundur/bonsaipress",
    "type": "project",
    "require": {
        "php": ">=8.2",
        "symfony/console": "^7.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.0"
    },
    "autoload": {
        "psr-4": {
            "BonsaiPress\\": "cms/src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "BonsaiPress\\Tests\\": "tests/"
        }
    },
    "config": {
        "sort-packages": true
    }
}
