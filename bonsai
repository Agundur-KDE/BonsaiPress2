#!/usr/bin/env bash

SCRIPT_DIR="$(cd "$(dirname "$(realpath "${BASH_SOURCE[0]}")")" && pwd)"
BONSAI_CONFIG="$HOME/.config/bonsai"
CLIENTS_DIR="$SCRIPT_DIR/clients"
PROJECTS_FILE="$BONSAI_CONFIG/projects.conf"
ACTIVE_FILE="$BONSAI_CONFIG/active"
DEMO_REPO="https://github.com/Agundur-KDE/DEMO.git"

# Dev mode: cms/ exists locally (git clone) — use compose.dev.yml with local build
# Standalone mode: cms/ is baked into the Docker image — use compose.yml (slim)
if [[ -d "$SCRIPT_DIR/cms" ]]; then
    COMPOSE_FILE="$SCRIPT_DIR/compose.dev.yml"
else
    COMPOSE_FILE="$SCRIPT_DIR/compose.yml"
fi

export UID
export GID
GID=$(id -g)

GREEN='\033[0;32m'
YELLOW='\033[1;33m'
RED='\033[0;31m'
BOLD='\033[1m'
RESET='\033[0m'

ok()   { echo -e "${GREEN}✓${RESET} $*"; }
info() { echo -e "${BOLD}▶${RESET} $*"; }
warn() { echo -e "${YELLOW}!${RESET} $*"; }
err()  { echo -e "${RED}✗${RESET} $*" >&2; }

# --- Config helpers ---

_config_init() {
    mkdir -p "$BONSAI_CONFIG" "$CLIENTS_DIR"
    [[ -f "$PROJECTS_FILE" ]] || touch "$PROJECTS_FILE"
}

_get_active() {
    [[ -f "$ACTIVE_FILE" ]] && cat "$ACTIVE_FILE" || echo ""
}

_set_active() {
    echo "$1" > "$ACTIVE_FILE"
}

_project_exists() {
    grep -q "^${1} " "$PROJECTS_FILE" 2>/dev/null
}

_get_git_url() {
    grep "^${1} " "$PROJECTS_FILE" | awk '{print $2}'
}

# --- Docker helpers ---

check_docker() {
    if ! command -v docker &>/dev/null; then
        err "Docker ist nicht installiert."
        err "Bitte Docker Desktop installieren: https://www.docker.com/products/docker-desktop"
        exit 1
    fi
    if ! docker info &>/dev/null; then
        err "Docker läuft nicht. Bitte Docker Desktop starten."
        exit 1
    fi
}

is_running() {
    docker compose -f "$COMPOSE_FILE" ps --status running 2>/dev/null | grep -q "cms"
}

_restart_if_running() {
    command -v docker &>/dev/null && docker info &>/dev/null 2>&1 || return
    if is_running; then
        info "Docker wird neu gestartet..."
        docker compose -f "$COMPOSE_FILE" restart > /dev/null 2>&1
        ok "Neugestartet."
    else
        info "BonsaiPress startet..."
        docker compose -f "$COMPOSE_FILE" up -d > /tmp/bonsai-start.log 2>&1 || {
            err "Fehler beim Starten:"; cat /tmp/bonsai-start.log; exit 1
        }
        ok "Bereit."
    fi
}

# --- Demo bootstrap ---

_ensure_demo() {
    [[ -e "$SCRIPT_DIR/current" ]] && return
    _config_init
    local demo_dir="$CLIENTS_DIR/DEMO"
    info "Kein Projekt aktiv — lade Demo..."
    git clone "$DEMO_REPO" "$demo_dir" 2>/dev/null || { err "Demo-Clone fehlgeschlagen (kein Internet?)."; exit 1; }
    _project_exists "DEMO" || echo "DEMO $DEMO_REPO" >> "$PROJECTS_FILE"
    ln -sfn "clients/DEMO" "$SCRIPT_DIR/current"
    _set_active "DEMO"
    ok "Demo bereit."
}

# --- System commands ---

start() {
    check_docker
    _ensure_demo

    if is_running; then
        ok "BonsaiPress läuft bereits."
        _show_urls
        return
    fi

    info "BonsaiPress startet..."
    docker compose -f "$COMPOSE_FILE" up -d > /tmp/bonsai-start.log 2>&1 || {
        err "Fehler beim Starten:"
        cat /tmp/bonsai-start.log
        exit 1
    }

    ok "Bereit."
    _show_urls
}

stop() {
    check_docker

    if ! is_running; then
        warn "BonsaiPress läuft nicht."
        return
    fi

    info "BonsaiPress wird gestoppt..."
    docker compose -f "$COMPOSE_FILE" down > /dev/null 2>&1
    ok "Gestoppt."
}

status() {
    check_docker

    local active
    active="$(_get_active)"

    if is_running; then
        ok "BonsaiPress läuft."
        [[ -n "$active" ]] && echo -e "  Aktives Projekt: ${BOLD}$active${RESET}"
        _show_urls
    else
        echo -e "  ${RED}●${RESET} BonsaiPress läuft nicht  →  ${BOLD}bonsai start${RESET}"
        echo ""
    fi

    # Remote-Check für aktives Projekt
    if [[ -n "$active" && -d "$CLIENTS_DIR/$active/.git" ]]; then
        if timeout 5 git -C "$CLIENTS_DIR/$active" fetch --quiet 2>/dev/null; then
            local behind ahead
            behind=$(git -C "$CLIENTS_DIR/$active" rev-list "HEAD..@{u}" --count 2>/dev/null || echo "0")
            ahead=$(git -C "$CLIENTS_DIR/$active" rev-list "@{u}..HEAD" --count 2>/dev/null || echo "0")
            if [[ "$behind" -gt 0 ]]; then
                warn "${active} ist ${behind} Commit(s) hinter origin — bitte pullen vor dem Weiterarbeiten"
            elif [[ "$ahead" -gt 0 ]]; then
                echo -e "  ${YELLOW}↑${RESET} ${active} ist ${ahead} Commit(s) vor origin — nicht gepusht"
            else
                echo -e "  ${GREEN}✓${RESET} ${active} ist aktuell"
            fi
        else
            echo -e "  ${YELLOW}~${RESET} ${active}: Remote nicht erreichbar"
        fi
        echo ""
    fi
}

_show_urls() {
    echo ""
    echo -e "  ${GREEN}●${RESET} Vorschau (dynamisch)  →  ${BOLD}http://localhost:8080${RESET}"
    echo -e "  ${GREEN}●${RESET} Vorschau (statisch)   →  ${BOLD}http://localhost:8081${RESET}"
    echo ""
}

# --- bp passthrough ---

run_bp() {
    check_docker

    if ! is_running; then
        err "BonsaiPress läuft nicht. Zuerst: bonsai start"
        exit 1
    fi

    docker compose -f "$COMPOSE_FILE" exec cms php /var/www/bin/bp "$@"
}

# --- Project management ---

list_cmd() {
    _config_init

    local active
    active="$(_get_active)"

    if [[ ! -s "$PROJECTS_FILE" ]]; then
        warn "Keine Projekte registriert."
        echo "  Projekt hinzufügen: bonsai add <name> <git-url>"
        return
    fi

    echo ""
    while read -r name git_url; do
        [[ -z "$name" || "$name" == \#* ]] && continue

        local client_dir="$CLIENTS_DIR/$name"
        local marker color extra

        if [[ "$name" == "$active" ]]; then
            marker="●"; color="$GREEN"
        else
            marker="○"; color="$RESET"
        fi

        if [[ -d "$client_dir/.git" ]]; then
            local last
            last=$(git -C "$client_dir" log -1 --format="%cr" 2>/dev/null || echo "?")
            extra="lokal  (letzter Commit: $last)"
        else
            extra="${YELLOW}→ wird beim Switch geklont${RESET}"
        fi

        echo -e "  ${color}${marker} ${BOLD}${name}${RESET}"
        echo    "    $git_url"
        echo -e "    $extra"
        echo ""
    done < "$PROJECTS_FILE"
}

switch_cmd() {
    local name="${1:-}"
    _config_init

    if [[ -z "$name" ]]; then
        err "Projektname fehlt. Beispiel: bonsai switch mykunde"
        exit 1
    fi

    if ! _project_exists "$name"; then
        err "Projekt '$name' nicht registriert."
        echo "  Verfügbare Projekte: bonsai list"
        echo "  Neu registrieren:    bonsai add $name <git-url>"
        exit 1
    fi

    local active
    active="$(_get_active)"

    if [[ "$name" == "$active" && -L "$SCRIPT_DIR/current" ]]; then
        ok "Projekt '$name' ist bereits aktiv."
        return
    fi

    # Uncommitted changes check
    if [[ -n "$active" && -d "$CLIENTS_DIR/$active/.git" ]]; then
        local changes
        changes=$(git -C "$CLIENTS_DIR/$active" status --porcelain 2>/dev/null)
        if [[ -n "$changes" ]]; then
            err "Projekt '$active' hat nicht committete Änderungen:"
            echo ""
            git -C "$CLIENTS_DIR/$active" status --short
            echo ""
            err "Bitte erst committen oder stashen."
            exit 1
        fi
    fi

    local git_url client_dir
    git_url="$(_get_git_url "$name")"
    client_dir="$CLIENTS_DIR/$name"

    if [[ ! -d "$client_dir/.git" ]]; then
        # First time: clone from remote
        info "Erstes Mal — klone '$name'..."
        if ! git clone "$git_url" "$client_dir"; then
            err "Clone fehlgeschlagen."
            exit 1
        fi
        git -C "$client_dir" submodule update --init --recursive --quiet
        ok "Geklont."
    else
        # Cached: try to fetch
        info "Prüfe Remote..."
        if timeout 10 git -C "$client_dir" fetch --quiet 2>/dev/null; then
            local behind
            behind=$(git -C "$client_dir" rev-list "HEAD..@{u}" --count 2>/dev/null || echo "0")
            if [[ "$behind" -gt 0 ]]; then
                warn "$behind neue Commits auf Remote."
                read -r -p "  Git pull durchführen? [J/n] " answer
                if [[ "${answer:-J}" =~ ^[Jj]$ ]]; then
                    git -C "$client_dir" pull --quiet
                    git -C "$client_dir" submodule update --init --recursive --quiet
                    ok "Aktualisiert."
                fi
            else
                ok "Lokal aktuell."
                git -C "$client_dir" submodule update --init --recursive --quiet
            fi
        else
            local last
            last=$(git -C "$client_dir" log -1 --format="%cr" 2>/dev/null || echo "unbekannt")
            warn "Remote nicht erreichbar — nutze lokalen Cache."
            echo -e "  ℹ Letzter Stand: $last"
            read -r -p "  Trotzdem wechseln? [J/n] " answer
            if [[ ! "${answer:-J}" =~ ^[Jj]$ ]]; then
                echo "Abgebrochen."
                exit 0
            fi
        fi
    fi

    # Update symlink and active marker
    info "Wechsle zu '$name'..."

    # If current/ is a real directory (not yet a symlink), check for changes and remove
    if [[ -d "$SCRIPT_DIR/current" && ! -L "$SCRIPT_DIR/current" ]]; then
        local dirty
        dirty=$(git -C "$SCRIPT_DIR/current" status --porcelain 2>/dev/null)
        if [[ -n "$dirty" ]]; then
            err "current/ ist noch kein Symlink und hat uncommittete Änderungen."
            err "Bitte erst in current/ committen und pushen, dann nochmal switch."
            exit 1
        fi
        rm -rf "$SCRIPT_DIR/current"
    fi

    ln -sfn "clients/$name" "$SCRIPT_DIR/current"
    _set_active "$name"

    # Bootstrap-Version aus Projekt auschecken
    local bs_version_file="$SCRIPT_DIR/current/config/bootstrap-version.txt"
    if [[ -f "$bs_version_file" ]]; then
        local bs_version
        bs_version=$(tr -d '"' < "$bs_version_file" | tr -d '[:space:]')
        if [[ -n "$bs_version" ]]; then
            info "Bootstrap: checkout $bs_version..."
            if git -C "$SCRIPT_DIR/cms/bootstrap" checkout "$bs_version" --quiet 2>/dev/null; then
                ok "Bootstrap $bs_version aktiv."
            else
                warn "Bootstrap-Version '$bs_version' nicht gefunden — bleibt auf aktuellem Stand."
            fi
        fi
    fi

    _restart_if_running

    echo ""
    ok "Aktives Projekt: ${BOLD}$name${RESET}"
    _show_urls
}

add_cmd() {
    local name="${1:-}" git_url="${2:-}"
    _config_init

    if [[ -z "$name" || -z "$git_url" ]]; then
        err "Verwendung: bonsai add <name> <git-url>"
        exit 1
    fi

    if _project_exists "$name"; then
        err "Projekt '$name' ist bereits registriert."
        exit 1
    fi

    echo "$name $git_url" >> "$PROJECTS_FILE"
    ok "Projekt '$name' registriert."
    echo "  Wechseln mit: bonsai switch $name"
}

remove_cmd() {
    local name="${1:-}"
    _config_init

    if [[ -z "$name" ]]; then
        err "Verwendung: bonsai remove <name>"
        exit 1
    fi

    if ! _project_exists "$name"; then
        err "Projekt '$name' nicht gefunden."
        exit 1
    fi

    local active
    active="$(_get_active)"
    if [[ "$name" == "$active" ]]; then
        err "Kann aktives Projekt nicht entfernen. Erst zu einem anderen wechseln."
        exit 1
    fi

    local tmpfile
    tmpfile=$(mktemp)
    grep -v "^${name} " "$PROJECTS_FILE" > "$tmpfile"
    mv "$tmpfile" "$PROJECTS_FILE"

    if [[ -d "$CLIENTS_DIR/$name" ]]; then
        read -r -p "  Lokalen Cache auch löschen? [j/N] " answer
        if [[ "${answer:-N}" =~ ^[Jj]$ ]]; then
            rm -rf "${CLIENTS_DIR:?}/$name"
            ok "Cache gelöscht."
        fi
    fi

    ok "Projekt '$name' entfernt."
}

# --- New project ---

new_cmd() {
    local name="${1:-}" remote_url="${2:-}"
    _config_init

    [[ -z "$name" ]] && { err "Verwendung: bonsai new <name> [<remote-url>]"; exit 1; }
    _project_exists "$name" && { err "Projekt '$name' ist bereits registriert."; exit 1; }

    local client_dir="$CLIENTS_DIR/$name"
    [[ -d "$client_dir" ]] && { err "Verzeichnis '$client_dir' existiert bereits."; exit 1; }

    # Template URL aus ~/.config/bonsai/config (BONSAI_TEMPLATE=...)
    local config_file="$BONSAI_CONFIG/config"
    local template_url=""
    [[ -f "$config_file" ]] && template_url=$(grep "^BONSAI_TEMPLATE=" "$config_file" | cut -d= -f2-)
    if [[ -z "$template_url" ]]; then
        err "Kein Template konfiguriert. Bitte in '$config_file' eintragen:"
        echo "  BONSAI_TEMPLATE=git@github.com:user/bonsai-template.git"
        exit 1
    fi

    # Template klonen, Git-History entfernen
    info "Klone Template..."
    git clone "$template_url" "$client_dir" || { err "Clone fehlgeschlagen."; exit 1; }
    git -C "$client_dir" submodule update --init --recursive --quiet
    rm -rf "$client_dir/.git"
    git -C "$client_dir" init
    ok "Git initialisiert."

    # Remote-URL (Argument oder interaktiv)
    if [[ -z "$remote_url" ]]; then
        read -r -p "  Remote-URL für '$name' (Enter = kein Remote): " remote_url
    fi
    if [[ -n "$remote_url" ]]; then
        git -C "$client_dir" remote add origin "$remote_url"
        ok "Remote: $remote_url"
    fi

    # Initialer Commit
    git -C "$client_dir" add -A
    git -C "$client_dir" commit -m "Initial commit"
    ok "Initialer Commit erstellt."

    # In projects.conf registrieren
    echo "$name ${remote_url:--}" >> "$PROJECTS_FILE"
    ok "Projekt '$name' registriert."

    # Automatisch wechseln (außer aktives Projekt hat uncommittete Änderungen)
    local active do_switch=1
    active="$(_get_active)"
    if [[ -n "$active" && -d "$CLIENTS_DIR/$active/.git" ]]; then
        local changes
        changes=$(git -C "$CLIENTS_DIR/$active" status --porcelain 2>/dev/null)
        if [[ -n "$changes" ]]; then
            warn "Aktives Projekt '$active' hat uncommittete Änderungen — nicht automatisch gewechselt."
            echo "  Wechseln mit: bonsai switch $name"
            do_switch=0
        fi
    fi

    if [[ "$do_switch" -eq 1 ]]; then
        ln -sfn "clients/$name" "$SCRIPT_DIR/current"
        _set_active "$name"
        _restart_if_running
        echo ""
        ok "Aktives Projekt: ${BOLD}$name${RESET}"
        _show_urls
    fi

    # Checklist für neue Nutzer
    echo ""
    info "Nächste Schritte:"
    echo -e "  1. ${BOLD}current/config/bonsai_config.php${RESET} ausfüllen (FTP, Domain)"
    echo -e "     ${YELLOW}⚠  Enthält Passwörter — bereits in .gitignore, nie committen!${RESET}"
    echo -e "  2. ${BOLD}bonsai static${RESET}   — statische HTML generieren"
    echo -e "  3. ${BOLD}bonsai deploy${RESET}   — deployen (legt web/ + include/ auf Server automatisch an)"
    echo -e "  4. CI/CD optional:  ${BOLD}https://github.com/Agundur-KDE/ftp-hash-deploy-action${RESET}"
    echo -e "     Ersetzt 'bonsai deploy' in GitHub Actions"
    echo ""

    # Push anbieten
    if [[ -n "$remote_url" ]]; then
        read -r -p "  Jetzt pushen? [J/n] " answer
        if [[ "${answer:-J}" =~ ^[Jj]$ ]]; then
            git -C "$client_dir" push -u origin HEAD || warn "Push fehlgeschlagen."
        fi
    fi
}

# --- Install ---

install_cmd() {
    local target="" self
    self="$(realpath "${BASH_SOURCE[0]}")"

    for dir in "$HOME/.local/bin" "$HOME/bin"; do
        if [[ ":$PATH:" == *":$dir:"* ]]; then
            target="$dir/bonsai"
            break
        fi
    done

    if [[ -z "$target" ]]; then
        err "Kein geeignetes Verzeichnis in PATH (~/.local/bin oder ~/bin)."
        err "Symlink manuell erstellen: ln -s $self ~/.local/bin/bonsai"
        exit 1
    fi

    if [[ -L "$target" ]]; then
        ln -sf "$self" "$target"
        ok "Aktualisiert: $target"
        return
    fi

    ln -s "$self" "$target"
    ok "Installiert: $target"
    ok "Du kannst jetzt überall 'bonsai' tippen."
}

# --- Help ---

help_cmd() {
    echo ""
    echo -e "  ${BOLD}BonsaiPress${RESET}"
    echo ""
    echo "  bonsai start                   System starten"
    echo "  bonsai stop                    System stoppen"
    echo "  bonsai restart                 Neustart"
    echo "  bonsai status                  Status und URLs anzeigen"
    echo ""
    echo "  bonsai list                    Alle Projekte anzeigen"
    echo "  bonsai new <name> [<url>]      Neues Projekt aus Template anlegen"
    echo "  bonsai switch <name>           Zu Projekt wechseln"
    echo "  bonsai add <name> <git-url>    Projekt registrieren"
    echo "  bonsai remove <name>           Projekt entfernen"
    echo ""
    echo "  bonsai static                  Statischen Export bauen"
    echo "  bonsai deploy                  Auf Server deployen"
    echo "  bonsai deploy -d               Deploy Vorschau (dry-run)"
    echo ""
    echo "  bonsai version                 Version anzeigen"
    echo "  bonsai update                  Docker-Images aktualisieren"
    echo "  bonsai install                 Einmalig: 'bonsai' überall verfügbar machen"
    echo ""
}

# --- Version ---

version_cmd() {
    if [[ -d "$SCRIPT_DIR/.git" ]]; then
        git -C "$SCRIPT_DIR" describe --tags 2>/dev/null || cat "$SCRIPT_DIR/VERSION" 2>/dev/null || echo "unknown"
    else
        cat "$SCRIPT_DIR/VERSION" 2>/dev/null || echo "unknown"
    fi
}

# --- Update ---

update_cmd() {
    check_docker
    info "Docker-Images werden aktualisiert..."
    docker compose -f "$COMPOSE_FILE" pull
    ok "Images aktuell."
    if is_running; then
        info "Container werden neu gestartet..."
        docker compose -f "$COMPOSE_FILE" up -d
        ok "Fertig."
    fi
}

# --- Router ---

case "${1:-help}" in
    start)          start ;;
    stop)           stop ;;
    restart)        stop; start ;;
    version|--version|-v) version_cmd ;;
    update)         update_cmd ;;
    status)         status ;;
    list)           list_cmd ;;
    new)            shift; new_cmd "$@" ;;
    switch)         shift; switch_cmd "$@" ;;
    add)            shift; add_cmd "$@" ;;
    remove)         shift; remove_cmd "$@" ;;
    static)
        shift
        # prod-CSS vor dem Export: kein source-map, komprimiert
        docker compose -f "$COMPOSE_FILE" exec watcher sass \
            --no-source-map --style=compressed \
            --silence-deprecation=mixed-decls \
            --load-path=cms/bootstrap/scss \
            --load-path=current/config/sass \
            current/config/sass/main.scss:current/static/_resources/css/main.css
        run_bp static "$@"
        ;;
    deploy)         shift; run_bp deploy "$@" ;;
    install)        install_cmd ;;
    help|--help|-h) help_cmd ;;
    *)
        err "Unbekannter Befehl: ${1}"
        echo "  Hilfe: bonsai help"
        exit 1
        ;;
esac
